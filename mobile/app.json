{
  "expo": {
    "name": "Student Focus",
    "slug": "nova-focus",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#050e18"
    },
    "ios": {
      "bundleIdentifier": "com.nova.novafocus",
      "supportsTablet": false,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.nova.appblocker"
        ]
      },
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "youtube",
          "instagram",
          "snssdk1233",
          "twitter",
          "snapchat",
          "fb",
          "reddit",
          "discord",
          "nflx",
          "spotify"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nova.novafocus",
      "adaptiveIcon": {
        "backgroundColor": "#050e18"
      },
      "permissions": [
        "android.permission.BIND_ACCESSIBILITY_SERVICE",
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.QUERY_ALL_PACKAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "./plugins/withAppBlocker"
    ],
    "extra": {
      "eas": {
        "projectId": "7ed76350-faaf-4a50-a4b9-98579425c7c4"
      }
    }
  }
}
